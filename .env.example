# API del backend Express.
# Dev local: dejar vacío para usar proxy de Vite a localhost:4000.
# Vercel: definir con URL accesible desde internet (ej. túnel HTTPS a tu backend local).
VITE_API_URL=

# Supabase (complemento: Auth en frontend). Crear proyecto en https://supabase.com
# Project Settings → API → Project URL y anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
