# Base de datos (requerido)
DATABASE_URL="file:./prisma/dev.db"

# Puerto del API (opcional, default 4000)
PORT=4000

# --- Reportes: correo (opcional; si no se configura, modo demo) ---
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-usuario
# SMTP_PASS=tu-password
# SMTP_FROM=reportes@tu-dominio.com

# --- Reportes: WhatsApp real con Twilio (opcional; si no se configura, modo demo) ---
# 1. Cuenta en https://www.twilio.com
# 2. En Consola: Account SID y Auth Token
# 3. WhatsApp Sandbox: únete al sandbox desde tu cel y usa el número que te den (ej. +14155238886)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
